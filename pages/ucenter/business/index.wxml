<view class="uc-biz">
  <image class="uc-biz__nav-bg" src="/static/bg_navbar.png" mode="aspectFill" />
  <t-navbar left-arrow title="商务合作" fixed safe-area-inset-top />

  <view class="uc-biz__body">
    <view wx:if="{{loading}}" class="uc-biz__loading">
      <t-loading size="40rpx" text="加载中…" />
    </view>

    <block wx:else>
      <view class="uc-biz__hero">
        <text class="uc-biz__hero-title">{{title}}</text>
        <text class="uc-biz__hero-desc">{{desc}}</text>
      </view>

      <!-- 双路径切换 -->
      <view class="uc-biz__tabs">
        <view
          class="uc-biz__tab {{activeTab === 'form' ? 'uc-biz__tab--active' : ''}}"
          data-tab="form"
          bindtap="onSwitchTab"
        >
          提交合作意向
        </view>
        <view
          class="uc-biz__tab {{activeTab === 'contact' ? 'uc-biz__tab--active' : ''}}"
          data-tab="contact"
          bindtap="onSwitchTab"
        >
          直接联系我们
        </view>
      </view>

      <!-- 路径 A：表单留资 -->
      <block wx:if="{{activeTab === 'form'}}">
        <view wx:if="{{submitted}}" class="uc-biz__card uc-biz__success">
          <view class="uc-biz__success-icon">
            <t-icon name="check-circle-filled" size="72rpx" />
          </view>
          <text class="uc-biz__success-title">意向已提交</text>
          <text class="uc-biz__success-desc">我们会在 1–2 个工作日内与您联系，也可切换到「直接联系我们」加微信沟通。</text>
          <view class="uc-biz__success-actions">
            <view class="uc-biz__ghost-btn" hover-class="uc-biz__ghost-btn--active" bindtap="onContinueSubmit">
              再提交一条
            </view>
            <view class="uc-biz__primary-btn" hover-class="uc-biz__primary-btn--active" bindtap="onGoContact">
              直接联系商务
            </view>
          </view>
        </view>

        <block wx:else>
          <view class="uc-biz__card">
            <text class="uc-biz__label">合作方身份 <text class="uc-biz__required">*</text></text>
            <view class="uc-biz__partner">
              <view
                class="uc-biz__partner-item {{form.partnerType === 'ENTERPRISE' ? 'uc-biz__partner-item--active' : ''}}"
                data-type="ENTERPRISE"
                bindtap="onSelectPartnerType"
              >
                <text class="uc-biz__partner-name">企业 / 机构</text>
                <text class="uc-biz__partner-desc">品牌、培训机构、高校等</text>
              </view>
              <view
                class="uc-biz__partner-item {{form.partnerType === 'INDIVIDUAL' ? 'uc-biz__partner-item--active' : ''}}"
                data-type="INDIVIDUAL"
                bindtap="onSelectPartnerType"
              >
                <text class="uc-biz__partner-name">个人</text>
                <text class="uc-biz__partner-desc">创作者、讲师、独立合作</text>
              </view>
            </view>
          </view>

          <view class="uc-biz__card" wx:if="{{types.length}}">
            <text class="uc-biz__label">合作方向 <text class="uc-biz__required">*</text></text>
            <view class="uc-biz__tags">
              <view
                wx:for="{{types}}"
                wx:key="*this"
                class="uc-biz__type {{form.cooperationType === item ? 'uc-biz__type--active' : ''}}"
                data-type="{{item}}"
                bindtap="onSelectType"
              >
                {{item}}
              </view>
            </view>
            <view class="uc-biz__field" wx:if="{{isOtherType}}" style="margin-top: 20rpx; margin-bottom: 0;">
              <text class="uc-biz__field-label">具体方向 <text class="uc-biz__required">*</text></text>
              <view class="uc-biz__field-control">
                <t-input
                  value="{{form.cooperationTypeCustom}}"
                  placeholder="没有合适选项时，请自行填写"
                  clearable
                  borderless
                  maxlength="{{64}}"
                  data-field="cooperationTypeCustom"
                  bind:change="onFieldInput"
                />
              </view>
            </view>
          </view>

          <view class="uc-biz__card">
            <text class="uc-biz__label">合作信息</text>

            <view class="uc-biz__field" wx:if="{{isEnterprise}}">
              <text class="uc-biz__field-label">公司 / 机构 <text class="uc-biz__required">*</text></text>
              <view class="uc-biz__field-control">
                <t-input
                  value="{{form.companyName}}"
                  placeholder="请输入公司或机构名称"
                  clearable
                  borderless
                  data-field="companyName"
                  bind:change="onFieldInput"
                />
              </view>
            </view>

            <view class="uc-biz__field" wx:else>
              <text class="uc-biz__field-label">所在单位（选填）</text>
              <view class="uc-biz__field-control">
                <t-input
                  value="{{form.companyName}}"
                  placeholder="如有所属机构可填写"
                  clearable
                  borderless
                  data-field="companyName"
                  bind:change="onFieldInput"
                />
              </view>
            </view>

            <view class="uc-biz__field">
              <text class="uc-biz__field-label">
                {{isEnterprise ? '联系人' : '您的姓名'}}
                <text class="uc-biz__required">*</text>
              </text>
              <view class="uc-biz__field-control">
                <t-input
                  value="{{form.contactName}}"
                  placeholder="{{isEnterprise ? '怎么称呼您' : '请输入真实姓名或称呼'}}"
                  clearable
                  borderless
                  data-field="contactName"
                  bind:change="onFieldInput"
                />
              </view>
            </view>

            <view class="uc-biz__field">
              <text class="uc-biz__field-label">手机号 <text class="uc-biz__required">*</text></text>
              <view class="uc-biz__field-control">
                <t-input
                  value="{{form.phone}}"
                  type="number"
                  maxlength="{{11}}"
                  placeholder="方便我们回拨联系"
                  clearable
                  borderless
                  data-field="phone"
                  bind:change="onFieldInput"
                />
              </view>
            </view>

            <view class="uc-biz__field">
              <text class="uc-biz__field-label">微信号（选填）</text>
              <view class="uc-biz__field-control">
                <t-input
                  value="{{form.wechat}}"
                  placeholder="便于后续沟通"
                  clearable
                  borderless
                  data-field="wechat"
                  bind:change="onFieldInput"
                />
              </view>
            </view>

            <view class="uc-biz__field">
              <text class="uc-biz__field-label">邮箱（选填）</text>
              <view class="uc-biz__field-control">
                <t-input
                  value="{{form.email}}"
                  placeholder="用于发送合作资料"
                  clearable
                  borderless
                  data-field="email"
                  bind:change="onFieldInput"
                />
              </view>
            </view>

            <view class="uc-biz__field uc-biz__field--textarea">
              <text class="uc-biz__field-label">合作需求 <text class="uc-biz__required">*</text></text>
              <view class="uc-biz__field-control uc-biz__field-control--textarea">
                <t-textarea
                  value="{{form.requirement}}"
                  placeholder="请简单描述合作目标、预期形式与时间（10–500 字）"
                  maxlength="{{500}}"
                  indicator
                  disable-default-padding
                  data-field="requirement"
                  bind:change="onFieldInput"
                />
              </view>
            </view>

            <t-button
              theme="primary"
              size="large"
              block
              shape="round"
              loading="{{submitting}}"
              disabled="{{submitting}}"
              bind:tap="onSubmit"
            >
              提交合作意向
            </t-button>
            <text class="uc-biz__form-tip">不想填表？可切换到上方「直接联系我们」</text>
          </view>
        </block>
      </block>

      <!-- 路径 B：直接联系 -->
      <block wx:if="{{activeTab === 'contact'}}">
        <view class="uc-biz__card">
          <text class="uc-biz__label">联系商务</text>
          <text class="uc-biz__hint">复制后打开微信添加，或保存二维码扫码联系</text>

          <view
            class="uc-biz__contact"
            hover-class="uc-biz__contact--active"
            bindtap="onCopyEmail"
          >
            <view class="uc-biz__contact-icon">
              <t-icon name="mail" size="40rpx" />
            </view>
            <view class="uc-biz__contact-main">
              <text class="uc-biz__contact-name">商务邮箱</text>
              <text class="uc-biz__contact-value">{{email || '暂未配置'}}</text>
            </view>
            <text class="uc-biz__contact-action">复制</text>
          </view>

          <view
            class="uc-biz__contact"
            hover-class="uc-biz__contact--active"
            bindtap="onCopyWechat"
          >
            <view class="uc-biz__contact-icon uc-biz__contact-icon--wechat">
              <t-icon name="logo-wechat-stroke" size="40rpx" />
            </view>
            <view class="uc-biz__contact-main">
              <text class="uc-biz__contact-name">商务微信</text>
              <text class="uc-biz__contact-value">{{wechat || '暂未配置'}}</text>
            </view>
            <text class="uc-biz__contact-action">复制</text>
          </view>
        </view>

        <view class="uc-biz__card" wx:if="{{qrcodeUrl}}">
          <text class="uc-biz__label">扫码联系</text>
          <text class="uc-biz__hint">长按或点击二维码可预览，也可保存到相册</text>
          <image
            class="uc-biz__qrcode"
            src="{{qrcodeUrl}}"
            mode="aspectFit"
            show-menu-by-longpress
            bindtap="onPreviewQrcode"
          />
          <view
            class="uc-biz__save"
            hover-class="uc-biz__save--active"
            bindtap="onSaveQrcode"
          >
            <t-icon name="download" size="32rpx" color="#fff" />
            <text>保存二维码</text>
          </view>
        </view>

        <view class="uc-biz__switch-hint" hover-class="uc-biz__switch-hint--active" bindtap="onSwitchTab" data-tab="form">
          <text>也可以填写意向表，我们主动联系你</text>
          <t-icon name="chevron-right" size="28rpx" />
        </view>
      </block>

      <view class="uc-biz__footer">
        <text>工作日一般 1–2 个工作日内回复</text>
      </view>
    </block>
  </view>
</view>
