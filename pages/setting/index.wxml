<t-navbar title="设置" left-arrow />
<view class="setting">
  <view class="setting__hero">
    <text class="setting__hero-title">面试助手设置</text>
    <text class="setting__hero-desc">围绕题库推荐、AI 答疑和练习记录做个性化配置</text>
  </view>

  <t-cell-group wx:for="{{menuData}}" wx:for-item="group" wx:key="index" t-class="cell-group-class" theme="card">
    <block wx:for="{{group}}" wx:for-item="item" wx:key="type">
      <t-cell
        wx:if="{{item.switchable}}"
        title="{{item.title}}"
        description="{{item.desc}}"
        bordered="{{true}}"
        leftIcon="{{item.icon}}"
      >
        <t-switch
          slot="note"
          value="{{settings[item.switchKey]}}"
          data-key="{{item.switchKey}}"
          bind:change="onSwitchChange"
        />
      </t-cell>

      <t-cell
        wx:else
        title="{{item.title}}"
        description="{{item.desc}}"
        note="{{item.noteKey ? (item.noteKey === 'defaultQuestionScope' ? (settings.defaultQuestionScope === 'all' ? '展示全部题库' : '我的职业优先') : historyCount + ' 条') : ''}}"
        hover
        arrow="{{item.type !== 'logout'}}"
        leftIcon="{{item.icon}}"
        data-item="{{item}}"
        bind:click="onMenuTap"
        t-class-title="{{item.theme === 'danger' ? 'setting__danger-title' : ''}}"
      />
    </block>
  </t-cell-group>
</view>

<t-picker
  visible="{{questionScopeVisible}}"
  title="题库默认展示"
  cancelBtn="取消"
  confirmBtn="确认"
  data-mode="questionScope"
  bind:cancel="hidePicker"
  bind:close="hidePicker"
  bind:change="onQuestionScopePick"
  value="{{[settings.defaultQuestionScope]}}"
>
  <t-picker-item options="{{questionScopeOptions}}" />
</t-picker>

<t-toast id="t-toast" />
