<t-navbar fixed="{{true}}" t-class="login-navbar" t-class-left="login-navbar-left">
  <view slot="left" class="login-nav-back" catchtap="goBack" aria-role="button" aria-label="返回">
    <t-icon name="chevron-left" size="38rpx" color="rgba(24,56,153,0.86)" />
  </view>
</t-navbar>

<view class="page login">
  <view class="login__bg-orb login__bg-orb--primary" />

  <view class="login__hero">
    <view class="login__hero-copy">
      <view class="login__eyebrow">
        <view class="login__eyebrow-dot" />
        <text>AI 面试陪练</text>
      </view>
      <text class="login__brand-name">面试胶囊</text>
      <text class="login__brand-desc">登录后，Agent 会结合你的职业方向，陪你练题、追问薄弱点，并给出复盘建议。</text>
    </view>

    <view class="login__ai-mark" aria-hidden="true">
      <text class="login__ai-mark-main">AI</text>
      <text class="login__ai-mark-sub">Agent</text>
    </view>
  </view>

  <view class="login__sheet">
    <view class="login__sheet-title">{{ isPasswordLogin ? '账号密码' : '手机号登录' }}</view>

    <view class="login__input">
      <view class="login__password" wx:if="{{isPasswordLogin}}">
        <t-input
          label="账号"
          placeholder="请输入手机号/邮箱"
          value="{{passwordInfo.username}}"
          bindchange="onAccountChange"
        />
        <t-input
          label="密码"
          placeholder="请输入密码"
          type="password"
          clearable
          value="{{passwordInfo.password}}"
          bindchange="onPasswordChange"
        />
      </view>

      <view wx:else class="login__phone-wrap">
        <t-input
          value="{{phoneNumber}}"
          placeholder="请输入手机号"
          type="number"
          maxlength="11"
          bindchange="onPhoneInput"
        >
          <view slot="label" class="input-label">
            <text class="input-label__cc">+86</text>
            <t-icon name="caret-down-small" size="36rpx" class="input-iconl" />
          </view>
        </t-input>
      </view>
    </view>

    <view class="login__tips">未注册的手机号验证通过后将自动注册</view>

    <view class="login__agree">
      <view class="login__agree-row">
        <t-radio-group
          allow-uncheck
          borderless
          value="{{radioValue}}"
          bind:change="onCheckChange"
          t-class="login-agree-radio-group"
        >
          <t-radio
            value="agree"
            label="阅读并同意"
            t-class="login-agree-radio"
            t-class-icon="login-agree-radio-icon"
            t-class-label="login-agree-radio-label"
          />
        </t-radio-group>
        <text class="login__agree-doc" catchtap="viewUserAgreement">《协议条款》</text>
      </view>
    </view>

    <view class="login__button">
      <t-button theme="primary" size="large" block disabled="{{!isSubmit}}" bindtap="login">
        {{ isPasswordLogin ? '登录' : '一键登录' }}
      </t-button>
    </view>

    <view class="login__password--forget" wx:if="{{isPasswordLogin}}">
      <text class="login__forget-txt">忘记密码？</text>
      <t-link theme="primary" size="small">找回密码</t-link>
    </view>

    <view class="login__mode-switch">
      <text class="login__mode-link" bindtap="changeLogin" >
        {{ isPasswordLogin ? '使用手机号一键登录' : '使用账号密码登录' }}
      </text>
    </view>
  </view>
</view>
