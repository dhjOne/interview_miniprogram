<view class="category-page">
  <image class="category-page__nav-bg" src="/static/bg_navbar.png" mode="aspectFill" />
  <nav nav-type="search" />

  <view class="category-page__body">
    <view wx:if="{{loading}}" class="category-loading">
      <t-loading size="48rpx" text="加载中..." />
    </view>

    <block wx:else>
      <view class="category-scope">
        <view class="category-scope__copy">
          <text class="category-scope__title">题库推荐</text>
          <text class="category-scope__desc">{{categoryScope === 'career' ? '按你选择的职业展示' : (isLoggedIn ? (hasProfession ? '展示全部题库分类' : '未选择职业，展示全部分类') : '未登录，展示全部分类')}}</text>
        </view>
        <view class="category-scope__tabs">
          <view
            wx:for="{{categoryScopeTabs}}"
            wx:key="value"
            class="category-scope__tab {{categoryScope === item.value ? 'is-active' : ''}}"
            data-scope="{{item.value}}"
            bindtap="onScopeTap"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view wx:if="{{primaryCategories.length}}" class="category-layout">
        <scroll-view class="category-rail" scroll-y show-scrollbar="{{false}}">
          <block wx:for="{{primaryCategories}}" wx:key="id">
            <view
              class="category-rail-item {{currentPrimaryId == item.id ? 'is-active' : ''}}"
              bindtap="switchPrimaryCategory"
              data-id="{{item.id}}"
              hover-class="category-rail-item--hover"
            >
              <text class="category-rail-text">{{item.name}}</text>
            </view>
          </block>
        </scroll-view>

        <scroll-view
          class="category-main-scroll"
          scroll-y
          enable-flex
          bindscrolltolower="loadMoreSecondaryCategories"
          lower-threshold="120"
          show-scrollbar="{{false}}"
        >
          <view class="category-main">
            <view wx:if="{{secondaryCategories.length}}" class="secondary-list">
              <block wx:for="{{secondaryCategories}}" wx:key="id">
                <view
                  class="secondary-row"
                  bindtap="switchSecondaryCategory"
                  data-id="{{item.id}}"
                  data-name="{{item.name}}"
                  hover-class="secondary-row--hover"
                >
                  <view class="secondary-row__icon" style="background: {{item.listIconBg}};">
                    <t-icon name="{{item.listIconName}}" size="34rpx" color="{{item.listIconColor}}" />
                  </view>
                  <text class="secondary-row__title">{{item.name}}</text>
                  <text wx:if="{{item.count !== undefined && item.count !== null}}" class="secondary-row__count">{{item.count}}</text>
                </view>
              </block>

              <view wx:if="{{secondaryLoadingMore}}" class="list-footer">
                <t-loading size="32rpx" text="加载中..." />
              </view>
              <view wx:elif="{{!secondaryHasMore}}" class="list-footer list-footer--end">
                <text>— 已加载全部 —</text>
              </view>
            </view>

            <view wx:elif="{{categoryLoading}}" class="category-inline-loading">
              <t-loading size="36rpx" text="加载中..." />
            </view>

            <view wx:elif="{{!categoryLoading}}" class="empty-state">
              <t-icon name="folder-open" size="72rpx" color="#cbd5e1" />
              <text class="empty-state__title">暂无二级分类</text>
            </view>
          </view>
        </scroll-view>
      </view>

      <view wx:else class="empty-state empty-state--page">
        <t-icon name="folder-open" size="72rpx" color="#cbd5e1" />
        <text class="empty-state__title">暂无分类</text>
      </view>
    </block>
  </view>
</view>

<float-release-button bind:onTap="onReleaseTap" />
<t-message id="t-message" />
