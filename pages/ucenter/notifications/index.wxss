.notify-page {
  min-height: 100vh;
  background: #f7f8fa;
  box-sizing: border-box;
}

/* t-navbar fixed 已自带 placeholder，这里不要再加 padding-top */
.notify-page__toolbar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx 16rpx;
  background: #f7f8fa;
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.06);
}

.notify-chips {
  flex: 1;
  min-width: 0;
  white-space: nowrap;
}

.notify-chips__row {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
}

.notify-chip {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #667085;
  background: #fff;
  border-radius: 999rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  line-height: 1.2;
}

.notify-chip--active {
  color: #fff;
  background: #1d4ed8;
  border-color: #1d4ed8;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(29, 78, 216, 0.22);
}

.notify-page__read-all {
  flex-shrink: 0;
  padding: 12rpx 8rpx;
  font-size: 24rpx;
  color: #1d4ed8;
  font-weight: 500;
}

.notify-page__read-all--disabled {
  opacity: 0.45;
}

.notify-page__body {
  padding: 8rpx 0 48rpx;
}

.notify-list {
  background: #fff;
  margin: 16rpx 24rpx 0;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 36rpx rgba(15, 23, 42, 0.04);
}

.notify-item {
  display: flex;
  gap: 20rpx;
  padding: 28rpx 28rpx 28rpx 24rpx;
  position: relative;
  background: #fff;
  border-bottom: 1rpx solid #f1f3f5;
}

.notify-item:last-child {
  border-bottom: none;
}

.notify-item--unread {
  background: linear-gradient(90deg, rgba(29, 78, 216, 0.05) 0%, #fff 42%);
}

.notify-item--unread::before {
  content: '';
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 6rpx;
  border-radius: 0 6rpx 6rpx 0;
  background: #1d4ed8;
}

.notify-item--active {
  background: #f8fafc;
}

.notify-item__avatar-wrap {
  position: relative;
  flex-shrink: 0;
  width: 88rpx;
  height: 88rpx;
}

.notify-item__avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #eef2ff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.notify-item__avatar--tone-blue {
  background: linear-gradient(135deg, #3b82f6, #1d4ed8);
}

.notify-item__avatar--tone-rose {
  background: linear-gradient(135deg, #fb7185, #e11d48);
}

.notify-item__avatar--tone-amber {
  background: linear-gradient(135deg, #fbbf24, #d97706);
}

.notify-item__avatar--tone-orange {
  background: linear-gradient(135deg, #fb923c, #ea580c);
}

.notify-item__avatar--tone-slate {
  background: linear-gradient(135deg, #94a3b8, #475569);
}

.notify-item__badge {
  position: absolute;
  right: -4rpx;
  bottom: -4rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.notify-item__badge--blue {
  background: #2563eb;
}

.notify-item__badge--rose {
  background: #e11d48;
}

.notify-item__badge--amber {
  background: #d97706;
}

.notify-item__badge--orange {
  background: #ea580c;
}

.notify-item__badge--slate {
  background: #64748b;
}

.notify-item__main {
  flex: 1;
  min-width: 0;
}

.notify-item__row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.notify-item__title {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notify-item__time {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.5;
  padding-top: 4rpx;
}

.notify-item__content {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #475569;
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-word;
}

.notify-item__meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 14rpx;
}

.notify-item__tag {
  font-size: 20rpx;
  color: #64748b;
  background: #f1f5f9;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  line-height: 1.4;
}

.notify-item__dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #2563eb;
}

.notify-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 180rpx 48rpx 80rpx;
  text-align: center;
}

.notify-empty__icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.05);
}

.notify-empty__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #334155;
  margin-bottom: 12rpx;
}

.notify-empty__desc {
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 1.5;
}

.notify-page__footer {
  padding: 28rpx 24rpx 40rpx;
  text-align: center;
}

.notify-page__end {
  font-size: 24rpx;
  color: #94a3b8;
}
