{
  "name": "interview-miniprogram",
  "version": "0.1.0",
  "main": "index.js",
  "scripts": {
    "prepare": "husky install",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint ./ --no-eslintrc -c ./.eslintrc.js",
    "lint:fix": "npm run lint:fix-eslint && npm run lint:fix-prettier",
    "lint:fix-eslint": "eslint --ext .js,.ts ./ --max-warnings 0 --ignore-path .gitignore --ignore-path .eslintignore --fix",
    "lint:fix-prettier": "prettier --write --ignore-path .gitignore --ignore-path .eslintignore --ignore-path .prettierignore './**/*.{js,ts}' --ignore-unknown"
  },
  "keywords": [
    "wechat",
    "miniprogram",
    "interview",
    "question-bank"
  ],
  "license": "MIT",
  "description": "面试题库微信小程序：分类刷题、发布文档、积分与个人中心",
  "dependencies": {
    "tdesign-miniprogram": "^1.11.2"
  },
  "devDependencies": {
    "eslint": "^8.49.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^8.0.3",
    "lint-staged": "^14.0.1",
    "prettier": "^3.0.2"
  }
}
