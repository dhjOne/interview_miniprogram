.ops-banner {
  position: relative;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.ops-banner--hover {
  opacity: 0.92;
}

.ops-banner--top {
  margin: 0 0 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(0, 82, 217, 0.08), rgba(54, 110, 244, 0.04));
  border: 1rpx solid rgba(0, 82, 217, 0.12);
}

.ops-banner--feed {
  margin: 0 0 16rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: #fff;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.04);
  border-left: 6rpx solid #0052d9;
}

.ops-banner__img {
  flex-shrink: 0;
  width: 96rpx;
  height: 72rpx;
  border-radius: 12rpx;
  background: rgba(15, 23, 42, 0.04);
}

.ops-banner--top .ops-banner__img {
  width: 120rpx;
  height: 72rpx;
}

.ops-banner__img--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.ops-banner__body {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
}

.ops-banner__meta {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.ops-banner__badge {
  align-self: flex-start;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: #0052d9;
  background: rgba(0, 82, 217, 0.1);
}

.ops-banner__title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ops-banner__close {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.ops-banner__close--hover {
  background: rgba(15, 23, 42, 0.06);
}

.ops-banner--top.ops-banner,
.ops-banner--feed.ops-banner {
  padding-right: 56rpx;
}
