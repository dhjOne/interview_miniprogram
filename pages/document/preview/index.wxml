<view class="doc-preview-page">
  <view wx:if="{{loading}}" class="doc-preview-loading">
    <t-loading size="48rpx" text="加载中…" />
  </view>

  <block wx:else>
    <!-- 全页展示 edit 预览模式样式 -->
    <scroll-view
      scroll-y
      class="preview-scroll preview-scroll--fullpage"
      enable-back-to-top="{{true}}"
      scroll-anchoring="{{true}}"
    >
      <towxml
        wx:if="{{renderedContent}}"
        nodes="{{renderedContent}}"
        type="markdown"
        class="preview-render"
      />
      <view wx:else class="preview-empty-content">
        <t-icon name="file" size="80" color="#c9cdd4" />
        <text class="preview-empty-text">暂无预览内容</text>
        <text class="preview-empty-subtext">文档可能为空或加载失败</text>
      </view>
    </scroll-view>

    <view class="doc-preview-footer">
      <t-button theme="primary" size="large" block bindtap="onGoEdit" wx:if="{{docId}}">
        编辑
      </t-button>
      <button class="doc-preview-share-btn" open-type="share">
        分享给好友
      </button>
    </view>
  </block>
</view>
