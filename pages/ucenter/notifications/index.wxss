.notification-page {
  min-height: 100vh;
  background: #f6f7fb;
}

.notification-page__body {
  padding: 188rpx 24rpx 48rpx;
}

.notification-card {
  display: flex;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(20, 36, 64, 0.06);
}

.notification-card--unread {
  border: 1rpx solid rgba(0, 82, 217, 0.18);
}

.notification-card__main {
  flex: 1;
  min-width: 0;
}

.notification-card__head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.notification-card__title {
  color: #1f2937;
  font-size: 30rpx;
  font-weight: 600;
}

.notification-card__dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #0052d9;
}

.notification-card__content {
  display: block;
  margin-top: 12rpx;
  color: #4b5563;
  font-size: 26rpx;
  line-height: 1.5;
}

.notification-card__time {
  display: block;
  margin-top: 14rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.notification-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 160rpx 0;
  color: #9ca3af;
  font-size: 28rpx;
}

.notification-page__footer {
  padding: 20rpx 0 40rpx;
  text-align: center;
}
