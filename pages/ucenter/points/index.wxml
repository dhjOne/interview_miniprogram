<view class="uc-points">
  <image class="uc-points__nav-bg" src="/static/bg_navbar.png" mode="aspectFill" />
  <t-navbar left-arrow title="创作激励" fixed safe-area-inset-top />

  <view class="uc-points__body">
    <!-- 积分资产卡 -->
    <view class="uc-points__hero">
      <view class="uc-points__hero-top">
        <view>
          <text class="uc-points__hero-label">可用积分</text>
          <text class="uc-points__hero-value">{{displayAvailable}}</text>
        </view>
        <view class="uc-points__hero-badge">
          <t-icon name="wallet" size="36rpx" color="#fff" />
        </view>
      </view>
      <text class="uc-points__hero-sub">发布内容、获得互动可赚取积分</text>
      <view class="uc-points__hero-stats">
        <view class="uc-points__hero-stat">
          <text class="uc-points__hero-stat-num">{{displayPending}}</text>
          <text class="uc-points__hero-stat-label">待结算</text>
        </view>
        <view class="uc-points__hero-stat-line" />
        <view class="uc-points__hero-stat">
          <text class="uc-points__hero-stat-num">{{displayEarned}}</text>
          <text class="uc-points__hero-stat-label">累计获得</text>
        </view>
        <view class="uc-points__hero-stat-line" />
        <view class="uc-points__hero-stat">
          <text class="uc-points__hero-stat-num">{{displaySpent}}</text>
          <text class="uc-points__hero-stat-label">累计消耗</text>
        </view>
      </view>
    </view>

    <!-- 快捷入口 -->
    <view class="uc-points__actions">
      <view class="uc-points__action" hover-class="uc-points__action--active" bindtap="goRedeem">
        <view class="uc-points__action-icon uc-points__action-icon--shop">
          <t-icon name="shop" size="40rpx" color="#0052d9" />
        </view>
        <text class="uc-points__action-name">兑换商城</text>
        <text class="uc-points__action-desc">积分兑权益</text>
      </view>
      <view class="uc-points__action" hover-class="uc-points__action--active" bindtap="goInvite">
        <view class="uc-points__action-icon uc-points__action-icon--invite">
          <t-icon name="user-add" size="40rpx" color="#0052d9" />
        </view>
        <text class="uc-points__action-name">邀请好友</text>
        <text class="uc-points__action-desc">双方拿奖励</text>
      </view>
      <view class="uc-points__action" hover-class="uc-points__action--active" bindtap="goAppeals">
        <view class="uc-points__action-icon uc-points__action-icon--appeal">
          <t-icon name="edit-1" size="40rpx" color="#0052d9" />
        </view>
        <text class="uc-points__action-name">我的申诉</text>
        <text class="uc-points__action-desc">追回可申诉</text>
      </view>
    </view>

    <!-- 赚积分规则 -->
    <view class="uc-points__card">
      <view class="uc-points__card-head" bindtap="toggleRules">
        <view>
          <text class="uc-points__card-title">如何获得积分</text>
          <text class="uc-points__card-desc">当前生效规则 {{ruleList.length}} 条</text>
        </view>
        <t-icon name="{{rulesExpanded ? 'chevron-up' : 'chevron-down'}}" size="36rpx" color="#94a3b8" />
      </view>
      <view wx:if="{{rulesExpanded}}" class="uc-points__rules-body">
        <view wx:if="{{rulesLoading}}" class="uc-points__inline-loading">
          <t-loading size="36rpx" text="加载规则…" />
        </view>
        <view wx:elif="{{ruleList.length === 0}}" class="uc-points__inline-empty">暂无规则说明</view>
        <view wx:else>
          <view wx:for="{{ruleList}}" wx:key="ruleCode" class="uc-points__rule-row">
            <view class="uc-points__rule-main">
              <text class="uc-points__rule-name">{{item.ruleName}}</text>
              <text class="uc-points__rule-meta" wx:if="{{item.cooldownHours > 0}}">到账周期约 {{item.cooldownHours}} 小时</text>
            </view>
            <text class="uc-points__rule-points">+{{item.basePoints}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 明细 -->
    <view class="uc-points__card uc-points__card--ledger">
      <view class="uc-points__card-head uc-points__card-head--static">
        <view>
          <text class="uc-points__card-title">积分明细</text>
          <text class="uc-points__card-desc">最近变动记录</text>
        </view>
      </view>

      <view wx:if="{{loading && ledgerList.length === 0 && !loadError}}" class="uc-points__loading">
        <t-loading size="48rpx" text="加载中…" />
      </view>

      <view wx:elif="{{!loading && loadDone && ledgerList.length === 0 && !loadError}}" class="uc-points__empty">
        <view class="uc-points__empty-icon">
          <t-icon name="wallet" size="64rpx" color="#c5cdd8" />
        </view>
        <text class="uc-points__empty-t">暂无积分记录</text>
        <text class="uc-points__empty-d">发布题目、获得互动即可赚取积分</text>
        <t-button class="uc-points__empty-btn" theme="primary" size="medium" shape="round" bind:tap="goCategory">
          去题库看看
        </t-button>
      </view>

      <view wx:elif="{{!loading && loadError}}" class="uc-points__empty">
        <t-icon name="error-circle" size="80rpx" color="#f5a524" />
        <text class="uc-points__empty-t">积分明细暂不可用</text>
        <text class="uc-points__empty-d">{{errorMessage || '服务升级中，请稍后再试'}}</text>
        <t-button theme="light" size="medium" shape="round" bind:tap="reload">重试</t-button>
      </view>

      <view wx:else class="uc-points__list">
        <view wx:for="{{ledgerList}}" wx:key="id" class="uc-points__row">
          <view class="uc-points__row-main">
            <text class="uc-points__row-title">{{item.bizLabel}}</text>
            <text class="uc-points__row-time">{{item.timeText}}</text>
            <text class="uc-points__row-settle" wx:if="{{item.status === 0 && item.settleText}}">
              预计到账 {{item.settleText}}
            </text>
            <text
              wx:if="{{item.canAppeal}}"
              class="uc-points__appeal-link"
              data-id="{{item.ledgerId}}"
              bindtap="onAppealTap"
            >
              积分被追回？去申诉
            </text>
          </view>
          <view class="uc-points__row-right">
            <text class="uc-points__amount uc-points__amount--{{item.amountClass}}">{{item.amountText}}</text>
            <t-tag size="small" variant="light" theme="{{item.statusTheme}}">{{item.statusLabel}}</t-tag>
          </view>
        </view>

        <view class="uc-points__foot" wx:if="{{ledgerList.length > 0}}">
          <view wx:if="{{loading}}">
            <t-loading size="36rpx" text="加载中…" />
          </view>
          <t-divider wx:elif="{{!hasMore}}" align="center" content="没有更多了" />
        </view>
      </view>
    </view>
  </view>

  <t-dialog
    visible="{{showAppealDialog}}"
    title="积分申诉"
    confirm-btn="{{appealSubmitting ? '提交中…' : '提交'}}"
    cancel-btn="取消"
    bind:confirm="onAppealConfirm"
    bind:cancel="onAppealDialogClose"
    bind:close="onAppealDialogClose"
  >
    <view slot="content" class="uc-points__appeal-form">
      <text class="uc-points__appeal-tip">流水号：{{appealLedgerId}}</text>
      <t-textarea
        value="{{appealReason}}"
        placeholder="请说明申诉原因，例如误判、系统异常等"
        maxlength="200"
        indicator
        bind:change="onAppealReasonChange"
      />
    </view>
  </t-dialog>
</view>
