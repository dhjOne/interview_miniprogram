.search-result-page {
  min-height: 100vh;
  padding: 24rpx 30rpx 48rpx;
  box-sizing: border-box;
  background: #f5f6f8;
}

.search-result__keyword {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 16rpx;
}

.search-result__label {
  font-size: 24rpx;
  color: #86909c;
}

.search-result__value {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d2129;
}

.search-result__section {
  margin-bottom: 24rpx;
  padding: 24rpx 28rpx;
  background: #fff;
  border-radius: 16rpx;
}

.search-result__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.search-result__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d2129;
}

.search-result__meta {
  font-size: 24rpx;
  color: #86909c;
}

.search-result__categories {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.search-result__category {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 24rpx;
  background: rgba(0, 82, 217, 0.06);
  border-radius: 999rpx;
}

.search-result__category--hover {
  opacity: 0.85;
}

.search-result__category-name {
  font-size: 26rpx;
  color: #0052d9;
}

.search-result__questions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.search-result__question {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f2f3f5;
}

.search-result__question:last-child {
  border-bottom: none;
}

.search-result__question--hover {
  opacity: 0.85;
}

.search-result__question-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.search-result__question-title {
  font-size: 28rpx;
  line-height: 1.5;
  color: #1d2129;
}

.search-result__question-category {
  font-size: 22rpx;
  color: #86909c;
}

.search-result__question-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
}

.search-result__question-view {
  font-size: 22rpx;
  color: #86909c;
}

.search-result__empty {
  padding: 40rpx 0;
}

.search-result__loading,
.search-result__footer {
  display: flex;
  justify-content: center;
  padding: 24rpx 0;
  font-size: 24rpx;
  color: #86909c;
}
