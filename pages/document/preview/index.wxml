<view class="doc-preview-page">
  <view wx:if="{{loading}}" class="doc-preview-loading">
    <t-loading size="48rpx" text="加载中…" />
  </view>

  <block wx:else>
    <scroll-view
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      class="preview-scroll"
      enable-back-to-top="{{true}}"
    >
      <view class="preview-card">
        <view class="preview-hero">
          <text wx:if="{{categoryName}}" class="preview-hero__category">{{categoryName}}</text>
          <text class="preview-hero__title">{{docTitle || '无标题'}}</text>
          <view wx:if="{{displayDate || viewCount !== ''}}" class="preview-hero__meta">
            <text wx:if="{{displayDate}}" class="preview-hero__meta-item">{{displayDate}}</text>
            <text wx:if="{{displayDate && viewCount !== ''}}" class="preview-hero__meta-dot">·</text>
            <text wx:if="{{viewCount !== ''}}" class="preview-hero__meta-item">{{viewCount}} 阅读</text>
          </view>
        </view>

        <view class="preview-body">
          <towxml
            wx:if="{{renderedContent}}"
            nodes="{{renderedContent}}"
            type="markdown"
            class="preview-render"
          />
          <view wx:else class="preview-empty-content">
            <t-icon name="file" size="80rpx" color="#c9cdd4" />
            <text class="preview-empty-text">暂无预览内容</text>
            <text class="preview-empty-subtext">文档可能为空或加载失败</text>
          </view>
        </view>
      </view>
      <view class="preview-scroll-spacer" />
    </scroll-view>

    <view class="preview-footer" wx:if="{{docId}}">
      <view class="preview-footer__dock">
        <view class="preview-footer__item" hover-class="preview-footer__item--active" bindtap="onGoEdit">
          <t-icon name="edit-1" size="40rpx" color="#0052d9" />
          <text class="preview-footer__label">编辑</text>
        </view>
        <view class="preview-footer__divider" />
        <button class="preview-footer__item preview-footer__share" open-type="share" hover-class="preview-footer__item--active">
          <t-icon name="share" size="40rpx" color="#0052d9" />
          <text class="preview-footer__label">分享</text>
        </button>
      </view>
    </view>
  </block>
</view>
