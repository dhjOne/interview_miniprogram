<view class="question-list-container">
  <view class="question-list-sticky">
    <view class="ql-filter">
      <view class="ql-filter__search">
        <t-search
          value="{{searchValue}}"
          placeholder="搜索题目标题…"
          bind:change="onSearchChange"
          bind:search="onSearch"
          bind:clear="onSearchClear"
          shape="round"
          t-class="ql-filter-search"
          t-class-input-container="ql-filter-search__box"
          t-class-input="ql-filter-search__input"
        />
      </view>

      <view class="ql-filter__sort-row">
        <text class="ql-filter__sort-label">排序</text>
        <view
          class="ql-sort-segment {{sortSwipePulse ? 'ql-sort-segment--pulse' : ''}}"
          bindtouchstart="onSortSwipeStart"
          bindtouchend="onSortSwipeEnd"
        >
          <view
            class="ql-sort-segment__thumb"
            style="width: {{sortThumbWidth}}%; transform: translateX({{sortThumbOffset}}%);"
          />
          <view
            wx:for="{{sortChips}}"
            wx:key="value"
            class="ql-sort-segment__item {{sortType === item.value ? 'ql-sort-segment__item--active' : ''}}"
            data-sort="{{item.value}}"
            bindtap="onSortTap"
          >
            {{item.label}}
          </view>
        </view>
      </view>
      <text class="ql-filter__swipe-tip">左右滑动排序条或题目列表可切换</text>

      <view class="ql-filter__meta" wx:if="{{listHeaderReady}}">
        <view class="ql-filter__meta-left">
          <text class="ql-filter__count">共 {{totalCount}} 道</text>
          <text wx:if="{{categoryName}}" class="ql-filter__dot">·</text>
          <text wx:if="{{categoryName}}" class="ql-filter__category">{{categoryName}}</text>
        </view>
        <text wx:if="{{searchValue}}" class="ql-filter__hint">关键词「{{searchValue}}」</text>
      </view>
    </view>
  </view>

  <view class="questions-section">
    <scroll-view
      class="questions-scroll"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      scroll-into-view="{{scrollIntoView}}"
      scroll-with-animation
      bindscroll="onPageScroll"
      bindscrolltolower="loadMore"
      bindtouchstart="onSortSwipeStart"
      bindtouchend="onSortSwipeEnd"
      lower-threshold="120">
      <view id="list-top" class="list-top-anchor" />
      <view class="question-list">
        <block wx:for="{{questionList}}" wx:key="id" wx:for-index="idx">
          <view
            class="question-item {{item.isCollected ? 'question-item--collected' : ''}}"
            bindtap="onQuestionClick"
            data-id="{{item.id}}"
            data-title="{{item.title}}">
            <view class="question-header">
              <view class="question-index">
                <text class="index-number">{{(page - 1) * pageSize + idx + 1}}</text>
              </view>
              <view class="question-main">
                <view class="question-title-row">
                  <text class="question-title">{{item.title || '无标题'}}</text>
                  <t-tag
                    wx:if="{{item.difficultyTag}}"
                    size="small"
                    theme="{{item.difficultyTag.theme}}"
                    class="question-diff-tag">
                    {{item.difficultyTag.text}}
                  </t-tag>
                </view>
                <view class="question-meta">
                  <text class="meta-item">
                    <t-icon name="time" size="24rpx" />
                    {{item.displayDate}}
                  </text>
                  <text class="meta-item">
                    <t-icon name="view" size="24rpx" />
                    {{item.viewCount}} 浏览
                  </text>
                  <text class="meta-item">
                    <t-icon name="app" size="24rpx" />
                    {{item.commentCount}} 评论
                  </text>
                  <text class="meta-item">
                    <t-icon name="thumb-up" size="24rpx" />
                    {{item.likeCount}} 点赞
                  </text>
                </view>
              </view>
              <view class="question-actions" catchtap="onCollect" data-id="{{item.id}}">
                <t-icon
                  name="{{item.isCollected ? 'heart-filled' : 'heart'}}"
                  size="40rpx"
                  color="{{item.isCollected ? '#07C160' : '#bbb'}}"
                  class="collect-icon"
                />
              </view>
            </view>

            <view wx:if="{{item.description}}" class="question-description">
              <text class="description-text">{{item.description}}</text>
            </view>
          </view>
        </block>
      </view>

      <view class="list-footer" wx:if="{{questionList.length > 0}}">
        <view class="list-footer-inner" wx:if="{{loading}}">
          <t-loading size="36rpx" text="加载中…" />
        </view>
        <t-divider wx:elif="{{!hasMore}}" align="center" content="没有更多了" />
      </view>

      <view wx:if="{{questionList.length === 0 && !loading}}" class="empty-state">
        <t-icon name="info-circle-filled" size="120rpx" color="#ddd" />
        <text class="empty-text">暂无题目</text>
        <text class="empty-desc">换个关键词试试，或发布一道题</text>
        <t-button theme="primary" size="large" bindtap="goRelease" class="empty-btn">
          发布题目
        </t-button>
      </view>

      <view wx:if="{{questionList.length === 0 && loading}}" class="list-loading-center">
        <t-loading size="48rpx" text="加载中…" />
      </view>
    </scroll-view>
  </view>
</view>

<view wx:if="{{showBackTop}}" class="back-top" bindtap="scrollToTop" hover-class="back-top-hover">
  <t-icon name="caret-up" size="32rpx" color="#fff" />
</view>

<float-release-button bind:onTap="onReleaseTap" />

<t-message id="t-message" />
