<t-toast id="t-toast" />

<view class="my-page">
  <image class="my-page__nav-bg" src="/static/bg_navbar.png" mode="aspectFill" />
  <nav title-text="我的" />

  <view class="my-page__body">
    <!-- 个人资料 + 创作中心入口 -->
    <t-cell-group theme="card" bordered="{{false}}" t-class="my-page__card-group">
      <view wx:if="{{isLoad}}" class="my-profile-card">
        <view class="my-profile-card__main">
          <t-avatar image="{{personalInfo.avatar || '/static/avatar1.png'}}" size="large" />
          <view class="my-profile">
            <view class="my-profile__name">{{personalInfo.nickname || '微信用户'}}</view>
            <view class="my-profile__bio-wrap">
              <t-tag class="my-profile__tag" size="small" variant="light" theme="primary">
                {{personalInfo.bio || '这个人很懒，什么都没有写'}}
              </t-tag>
            </view>
          </view>
        </view>
        <view class="my-profile-card__actions">
          <view class="my-profile-card__action" hover-class="my-profile-card__action--active" bindtap="onNavigateTo">
            <t-icon name="edit" size="34rpx" />
          </view>
          <view class="my-profile-card__setting" hover-class="my-profile-card__setting--active" bindtap="onSettingTap">
            <t-icon name="setting" size="32rpx" />
            <text>设置</text>
          </view>
        </view>
      </view>

      <view class="my-stats" wx:if="{{isLoad}}">
        <view
          wx:for="{{socialStats}}"
          wx:key="type"
          class="my-stats__item"
          data-item="{{item}}"
          bindtap="onSocialStatTap"
        >
          <text class="my-stats__num">{{item.displayCount}}</text>
          <text class="my-stats__label">{{item.label}}</text>
        </view>
      </view>

      <t-cell
        wx:if="{{!isLoad}}"
        title="请先登录 / 注册"
        bordered="{{false}}"
        t-class-title="my-page__login-title"
        t-class-center="my-page__login-center"
        bindtap="onLogin"
      >
        <t-avatar slot="left-icon" icon="user" size="large" />
      </t-cell>

      <t-divider t-class="my-page__divider" />

      <view class="my-page__section-head my-page__section-head--row my-page__section-head--creator">
        <view class="my-page__section-head-main">
          <text class="my-page__section-title">创作中心</text>
          <text class="my-page__section-desc">{{isLoad ? creatorPreviewText : '登录后管理作品与数据'}}</text>
        </view>
        <view
          class="my-page__section-more"
          hover-class="my-page__section-more--active"
          bindtap="onCreatorCenterTap"
        >
          <text>全部</text>
          <t-icon name="chevron-right" size="28rpx" />
        </view>
      </view>

      <t-grid column="4" t-class="my-page__publish-grid">
        <t-grid-item
          wx:for="{{creatorGridList}}"
          wx:for-item="gridItem"
          wx:key="type"
          text="{{gridItem.name}}"
          icon="{{gridItem.icon}}"
          class="my-page__publish-item"
          data-data="{{gridItem}}"
          bindclick="onCreatorGridTap"
        />
      </t-grid>
    </t-cell-group>

    <!-- 运营轮播 -->
    <view class="my-page__card my-page__card--media">
      <swiper
        class="my-page__swiper"
        indicator-dots="{{true}}"
        autoplay="{{true}}"
        interval="{{5000}}"
        duration="{{500}}"
        circular="{{true}}"
        indicator-color="rgba(255,255,255,0.45)"
        indicator-active-color="#ffffff"
      >
        <swiper-item wx:for="{{carousel}}" wx:key="title" class="my-page__swiper-item">
          <image src="{{item.image}}" mode="aspectFill" class="my-page__swiper-img" />
          <view class="my-page__swiper-mask" />
          <view class="my-page__swiper-caption">{{item.title}}</view>
        </swiper-item>
      </swiper>
    </view>

    <!-- 常用服务 -->
    <view class="my-page__card my-page__card--tools">
      <view class="my-page__section-head my-page__section-head--row">
        <view class="my-page__section-head-main">
          <text class="my-page__section-title">常用服务</text>
          <text class="my-page__section-desc">本地浏览 {{historyCount}} 条 · 收藏与排行需登录</text>
        </view>
      </view>

      <view class="my-page__service-row">
        <block wx:for="{{service}}" wx:key="type" wx:for-item="item">
          <button
            wx:if="{{item.type === 'contact'}}"
            class="my-service-tile my-service-tile--contact my-service-tile--btn"
            hover-class="my-service-tile--active"
            open-type="contact"
            bindcontact="handleContact"
          >
            <view class="my-service-tile__icon">
              <t-icon name="{{item.icon}}" size="44rpx" />
            </view>
            <text class="my-service-tile__text">{{item.name}}</text>
          </button>
          <view
            wx:else
            class="my-service-tile my-service-tile--{{item.type}}"
            hover-class="my-service-tile--active"
            data-item="{{item}}"
            bindtap="onServiceItemTap"
          >
            <view class="my-service-tile__icon">
              <t-icon name="{{item.icon}}" size="44rpx" />
            </view>
            <text class="my-service-tile__text">{{item.name}}</text>
          </view>
        </block>
      </view>
    </view>
  </view>
</view>
