<!-- pages/question/detail/index.wxml -->
<view class="question-detail-container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-content">
      <t-loading size="60rpx" text="加载中..."></t-loading>
    </view>
  </view>

  <!-- 错误状态 -->
  <view wx:elif="{{error}}" class="error-state">
    <view class="error-content">
      <t-icon name="error-circle" size="120rpx" color="#ff4d4f"></t-icon>
      <text class="error-text">{{errorMessage || '加载失败'}}</text>
      <t-button theme="primary" bindtap="retryLoad" class="retry-btn">
        重新加载
      </t-button>
    </view>
  </view>

  <!-- 空数据状态 -->
  <view wx:elif="{{isEmpty}}" class="empty-state">
    <view class="empty-content">
      <t-icon name="file" size="120rpx" color="#ccc"></t-icon>
      <text class="empty-text">题目不存在</text>
      <text class="empty-desc">该题目可能已被删除或不存在</text>
      <t-button theme="outline" bindtap="goBack" class="empty-btn">
        返回上一页
      </t-button>
    </view>
  </view>

  <!-- 正常内容 -->
  <view wx:else class="detail-main">
    <scroll-view class="content-scroll" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="question-card">
        <view class="detail-hero">
          <text wx:if="{{questionDetail.categoryName}}" class="detail-hero__category">{{questionDetail.categoryName}}</text>
          <text class="detail-hero__title">{{questionDetail.title}}</text>
          <view wx:if="{{questionDetail.createdAt || questionDetail.viewCount || questionDetail.wordCount}}" class="detail-hero__meta">
            <text wx:if="{{questionDetail.createdAt}}" class="detail-hero__meta-item">{{questionDetail.createdAt}}</text>
            <text wx:if="{{questionDetail.createdAt && questionDetail.viewCount}}" class="detail-hero__meta-dot">·</text>
            <text wx:if="{{questionDetail.viewCount}}" class="detail-hero__meta-item">{{questionDetail.viewCount}} 阅读</text>
            <text wx:if="{{questionDetail.viewCount && questionDetail.wordCount}}" class="detail-hero__meta-dot">·</text>
            <text wx:if="{{questionDetail.wordCount}}" class="detail-hero__meta-item">{{questionDetail.wordCount}} 字</text>
          </view>
        </view>

        <view class="detail-author {{isSelfAuthor ? 'detail-author--self' : ''}}">
          <view class="detail-author__main" catchtap="onAuthorTap" hover-class="detail-author__main--pressed">
            <view class="detail-author__avatar">
              <image
                wx:if="{{questionDetail.authorAvatar || questionDetail.createAvatar}}"
                class="detail-author__avatar-img"
                src="{{questionDetail.authorAvatar || questionDetail.createAvatar}}"
                mode="aspectFill"
              />
              <t-icon wx:else name="user-circle" size="44rpx" color="#0052d9" />
            </view>
            <view class="detail-author__copy">
              <text class="detail-author__name">{{authorDisplayName}}</text>
              <text class="detail-author__hint">{{isSelfAuthor ? '我的主页' : '点击查看作者主页'}}</text>
            </view>
          </view>
          <view
            wx:if="{{!isSelfAuthor}}"
            class="detail-author__follow {{authorFollowing ? 'detail-author__follow--followed' : ''}}"
            hover-class="detail-author__follow--pressed"
            bindtap="onToggleFollow"
          >
            <t-icon
              wx:if="{{!authorFollowing}}"
              name="add"
              size="26rpx"
              class="detail-author__follow-icon"
            />
            <t-icon
              wx:else
              name="check"
              size="26rpx"
              class="detail-author__follow-icon detail-author__follow-icon--muted"
            />
            <text>{{authorFollowing ? '已关注' : '关注'}}</text>
          </view>
        </view>

        <view class="content-area">
          <block wx:if="{{isMarkdown && towxmlData}}">
            <view class="markdown-content">
              <towxml nodes="{{towxmlData}}" />
            </view>
          </block>

          <block wx:else>
            <view class="content-blocks">
              <block wx:for="{{contentBlocks}}" wx:key="id" wx:for-index="index">
                <view wx:if="{{item.blockType === 'text'}}" class="content-block text-block {{item.customClass}}"
                  style="{{item.customStyle}}" data-block-id="{{item.id}}" data-block-type="text">
                  <block wx:if="{{item.textInfo.hasLineBreaks}}">
                    <block wx:for="{{item.textInfo.lines}}" wx:key="index">
                      <view class="text-line {{index > 0 ? 'indented-line' : ''}}">
                        <rich-text wx:if="{{item.textInfo.hasBoldText || item.contentFormat === 'markdown'}}"
                          nodes="{{item}}" class="rich-text-content">
                        </rich-text>
                        <text wx:else class="text-content" selectable>{{item}}</text>
                      </view>
                    </block>
                  </block>
                  <block wx:else>
                    <rich-text wx:if="{{item.textInfo.hasBoldText || item.contentFormat === 'markdown'}}"
                      nodes="{{item.textInfo.formattedContent}}" class="rich-text-content">
                    </rich-text>
                    <text wx:else class="text-content" selectable>{{item.textInfo.formattedContent}}</text>
                  </block>
                </view>

                <view wx:elif="{{item.blockType === 'code'}}" class="content-block code-block {{item.customClass}}"
                  style="{{item.customStyle}}" data-block-id="{{item.id}}" data-block-type="code" bindtap="onBlockTap">
                  <view class="code-header">
                    <text class="code-language">{{item.formattedContent.language}}</text>
                    <view class="code-actions" catchtap="copyCode" data-content="{{item.content}}">
                      <t-icon name="copy" size="24rpx"></t-icon>
                      <text>复制</text>
                    </view>
                  </view>
                  <view class="code-content">
                    <text class="code-text" selectable>{{item.content}}</text>
                  </view>
                </view>

                <view wx:elif="{{item.blockType === 'image'}}" class="content-block image-block {{item.customClass}}"
                  style="{{item.customStyle}}" data-block-id="{{item.id}}" data-block-type="image" bindtap="onBlockTap">
                  <image src="{{item.imageInfo.src}}" mode="widthFix" class="content-image"
                    data-src="{{item.imageInfo.src}}"></image>
                  <view wx:if="{{item.imageInfo.caption}}" class="image-caption">
                    {{item.imageInfo.caption}}
                  </view>
                </view>

                <view wx:elif="{{item.blockType === 'table'}}" class="content-block table-block {{item.customClass}}"
                  style="{{item.customStyle}}" data-block-id="{{item.id}}" data-block-type="table">
                  <view class="table-container">
                    <view class="table-row table-header">
                      <block wx:for="{{item.tableData.headers}}" wx:key="*this">
                        <view class="table-cell header-cell">{{item}}</view>
                      </block>
                    </view>
                    <block wx:for="{{item.tableData.rows}}" wx:key="index">
                      <view class="table-row">
                        <block wx:for="{{item}}" wx:key="*this">
                          <view class="table-cell">{{item}}</view>
                        </block>
                      </view>
                    </block>
                  </view>
                </view>

                <view wx:elif="{{item.blockType === 'formula'}}"
                  class="content-block formula-block {{item.customClass}} {{item.formulaInfo.isInline ? 'formula-inline' : 'formula-block'}}"
                  style="{{item.customStyle}}" data-block-id="{{item.id}}" data-block-type="formula">
                  <view class="formula-content">{{item.content}}</view>
                </view>

                <view wx:elif="{{item.blockType === 'file'}}" class="content-block file-block {{item.customClass}}"
                  style="{{item.customStyle}}" data-block-id="{{item.id}}" data-block-type="file" bindtap="onBlockTap">
                  <view class="file-info">
                    <t-icon name="file" size="40rpx"></t-icon>
                    <view class="file-details">
                      <text class="file-name">{{item.fileInfo.fileName}}</text>
                      <text class="file-size">{{item.fileInfo.fileSize}}</text>
                    </view>
                    <t-icon name="download" size="32rpx"></t-icon>
                  </view>
                </view>

                <view wx:elif="{{item.blockType === 'divider'}}"
                  class="content-block divider-block {{item.customClass}}" style="{{item.customStyle}}"
                  data-block-id="{{item.id}}" data-block-type="divider">
                </view>

                <view wx:elif="{{item.blockType === 'video'}}" class="content-block video-block {{item.customClass}}"
                  style="{{item.customStyle}}" data-block-id="{{item.id}}" data-block-type="video">
                  <video src="{{item.videoInfo.src}}" poster="{{item.videoInfo.poster}}"
                    controls="{{item.videoInfo.controls}}" autoplay="{{item.videoInfo.autoplay}}"
                    class="content-video"></video>
                </view>

                <view wx:else class="content-block unknown-block">
                  <text>未知块类型: {{item.blockType}}</text>
                </view>
              </block>
            </view>
          </block>
        </view>
      </view>

      <view class="bottom-placeholder"></view>
    </scroll-view>

    <!-- 底部导航栏 -->
    <view class="detail-bottom-bar">
      <view class="bottom-bar__dock">
        <view class="bottom-tool" hover-class="bottom-tool--pressed" bindtap="onOpenCatalog">
          <view class="bottom-tool__icon">
            <t-icon name="view-list" size="40rpx" color="#64748b" />
          </view>
          <text class="bottom-tool__label">目录</text>
        </view>

        <view class="bottom-tool" hover-class="bottom-tool--pressed" bindtap="onOpenComments">
          <view class="bottom-tool__icon">
            <t-icon name="chat" size="40rpx" color="#64748b" />
            <text wx:if="{{commentCount}}" class="bottom-tool__badge">{{commentCount > 99 ? '99+' : commentCount}}</text>
          </view>
          <text class="bottom-tool__label">评论</text>
        </view>

        <view class="bottom-bar__divider" />

        <view
          class="bottom-tool {{questionDetail.liked ? 'bottom-tool--active' : ''}}"
          hover-class="bottom-tool--pressed"
          bindtap="onLike"
        >
          <view class="bottom-tool__icon">
            <t-icon
              name="{{questionDetail.liked ? 'thumb-up-filled' : 'thumb-up'}}"
              size="40rpx"
              color="{{questionDetail.liked ? '#0052d9' : '#64748b'}}"
            />
          </view>
          <text class="bottom-tool__label">{{questionDetail.likeCount > 0 ? questionDetail.likeCount : '点赞'}}</text>
        </view>

        <view
          class="bottom-tool {{questionDetail.collected ? 'bottom-tool--active' : ''}}"
          hover-class="bottom-tool--pressed"
          bindtap="onCollect"
        >
          <view class="bottom-tool__icon">
            <t-icon
              name="{{questionDetail.collected ? 'heart-filled' : 'heart'}}"
              size="40rpx"
              color="{{questionDetail.collected ? '#0052d9' : '#64748b'}}"
            />
          </view>
          <text class="bottom-tool__label">{{questionDetail.collectCount > 0 ? questionDetail.collectCount : '收藏'}}</text>
        </view>

        <view class="bottom-tool" hover-class="bottom-tool--pressed" bindtap="onShare">
          <view class="bottom-tool__icon">
            <t-icon name="share" size="40rpx" color="#64748b" />
          </view>
          <text class="bottom-tool__label">分享</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 题目目录侧栏 -->
<t-popup
  visible="{{showCatalog}}"
  placement="left"
  bind:visible-change="onCatalogVisibleChange"
>
  <view class="catalog-drawer">
    <view class="catalog-drawer__head">
      <text class="catalog-drawer__title">题目目录</text>
      <text class="catalog-drawer__sub">{{catalogTitle}}</text>
    </view>

    <view wx:if="{{catalogLoading && !catalogList.length}}" class="catalog-drawer__loading">
      <t-loading size="48rpx" text="加载目录…"></t-loading>
    </view>

    <scroll-view
      wx:else
      class="catalog-drawer__list"
      scroll-y
      show-scrollbar="{{false}}"
      bindscrolltolower="loadMoreCatalog"
      lower-threshold="120"
    >
      <view wx:if="{{!catalogList.length && !catalogLoading}}" class="catalog-drawer__empty">
        <t-icon name="folder-open" size="80rpx" color="#ccc"></t-icon>
        <text>暂无同分类题目</text>
        <text class="catalog-drawer__empty-hint">从题库列表进入可浏览完整目录</text>
      </view>

      <view
        wx:for="{{catalogList}}"
        wx:key="id"
        class="catalog-item {{item.id == questionId ? 'catalog-item--active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onCatalogItemTap"
      >
        <text class="catalog-item__index">{{item.index}}</text>
        <view class="catalog-item__main">
          <text class="catalog-item__title">{{item.title}}</text>
          <text wx:if="{{item.displayDate}}" class="catalog-item__meta">{{item.displayDate}}</text>
        </view>
        <t-icon wx:if="{{item.id == questionId}}" name="check-circle-filled" size="36rpx" color="#0052d9"></t-icon>
      </view>

      <view wx:if="{{catalogList.length}}" class="catalog-drawer__footer">
        <view wx:if="{{catalogLoadingMore}}" class="catalog-drawer__footer-loading">
          <t-loading size="32rpx" text="加载中..." />
        </view>
        <text wx:elif="{{!catalogHasMore}}" class="catalog-drawer__footer-end">— 已加载全部 —</text>
      </view>
    </scroll-view>
  </view>
</t-popup>

<!-- 评论底部面板 -->
<t-popup
  visible="{{showCommentPanel}}"
  placement="bottom"
  bind:visible-change="onCommentPanelVisibleChange"
>
  <view class="comment-panel">
    <view class="comment-panel__head">
      <view class="comment-panel__handle"></view>
      <view class="comment-panel__head-main">
        <text class="comment-panel__title">{{commentCount || 0}} 条评论</text>
        <text wx:if="{{comments.length}}" class="comment-panel__stats">{{comments.length}} 条主评论 · {{commentCount || 0}} 条总计</text>
      </view>
      <view class="comment-panel__close" bindtap="onCloseComments">
        <t-icon name="close" size="36rpx" color="#999"></t-icon>
      </view>
    </view>

    <scroll-view
      class="comment-panel__list"
      scroll-y
      show-scrollbar="{{false}}"
      bindscrolltolower="loadMoreComments"
      lower-threshold="120"
    >
      <view wx:if="{{commentLoading && !comments.length}}" class="comment-panel__empty">
        <t-loading size="48rpx" text="加载评论…" />
      </view>

      <view wx:elif="{{!comments.length && !commentLoading}}" class="comment-panel__empty">
        <t-icon name="chat" size="64rpx" color="#ddd"></t-icon>
        <text>还没有评论，来抢沙发吧</text>
      </view>

      <block wx:for="{{comments}}" wx:key="id">
        <view class="comment-row {{replyHighlightId == item.id ? 'comment-row--highlight' : ''}}">
          <image class="comment-row__avatar" src="{{item.avatar || '/static/avatar1.png'}}" mode="aspectFill"></image>
          <view class="comment-row__main">
            <text class="comment-row__name">{{item.userName || item.nickname || '匿名用户'}}</text>
            <text class="comment-row__content">{{item.content}}</text>
            <view class="comment-row__meta">
              <text class="comment-row__time">{{item.createTime || item.timeText}}</text>
              <text
                class="comment-row__reply {{replyHighlightId == item.id ? 'comment-row__reply--active' : ''}}"
                bindtap="onReplyComment"
                data-id="{{item.id}}"
                data-root-id="{{item.id}}"
                data-name="{{item.userName || item.nickname || '匿名用户'}}"
                data-content="{{item.content}}"
              >回复</text>
              <text
                class="comment-row__reply"
                bindtap="onReportComment"
                data-id="{{item.id}}"
                data-user-id="{{item.userId}}"
                data-content="{{item.content}}"
              >举报</text>
            </view>

            <view
              wx:if="{{item.replyCount > 0 || item.replies.length || item.repliesLoaded}}"
              class="comment-replies-toggle"
              bindtap="onToggleReplies"
              data-id="{{item.id}}"
            >
              <view class="comment-replies-toggle__line"></view>
              <text wx:if="{{item.repliesLoading || replyLoadingIds[item.id]}}" class="comment-replies-toggle__text">回复加载中…</text>
              <text wx:else class="comment-replies-toggle__text">
                {{expandedReplyIds[item.id] ? '收起回复' : '展开 ' + (item.repliesLoaded ? item.replies.length : item.replyCount) + ' 条回复'}}
              </text>
              <t-icon wx:if="{{!item.repliesLoading && !replyLoadingIds[item.id]}}" name="{{expandedReplyIds[item.id] ? 'chevron-up' : 'chevron-down'}}" size="28rpx" color="#999"></t-icon>
            </view>

            <view wx:if="{{expandedReplyIds[item.id] && item.replies.length}}" class="comment-row__replies">
              <block wx:for="{{item.replies}}" wx:for-item="reply" wx:key="id">
                <view class="comment-row comment-row--reply {{replyHighlightId == reply.id ? 'comment-row--highlight' : ''}}">
                  <image class="comment-row__avatar comment-row__avatar--small" src="{{reply.avatar || '/static/avatar1.png'}}" mode="aspectFill"></image>
                  <view class="comment-row__main">
                    <text class="comment-row__name">{{reply.userName || reply.nickname || '匿名用户'}}</text>
                    <view class="comment-row__content">
                      <text class="comment-row__reply-to">回复 </text>
                      <text class="comment-row__reply-target">@{{reply.replyToName || '匿名用户'}}</text>
                      <text class="comment-row__content-text">：{{reply.content}}</text>
                    </view>
                    <view class="comment-row__meta">
                      <text class="comment-row__time">{{reply.createTime || reply.timeText}}</text>
                      <text
                        class="comment-row__reply {{replyHighlightId == reply.id ? 'comment-row__reply--active' : ''}}"
                        bindtap="onReplyComment"
                        data-id="{{reply.id}}"
                        data-root-id="{{item.id}}"
                        data-name="{{reply.userName || reply.nickname || '匿名用户'}}"
                        data-content="{{reply.content}}"
                      >回复</text>
                      <text
                        class="comment-row__reply"
                        bindtap="onReportComment"
                        data-id="{{reply.id}}"
                        data-user-id="{{reply.userId}}"
                        data-content="{{reply.content}}"
                      >举报</text>
                    </view>
                  </view>
                  <view
                    class="comment-row__like {{likedCommentIds[reply.id] ? 'comment-row__like--active' : ''}}"
                    bindtap="onLikeComment"
                    data-id="{{reply.id}}"
                  >
                    <t-icon
                      name="{{likedCommentIds[reply.id] ? 'thumb-up-filled' : 'thumb-up'}}"
                      size="28rpx"
                      color="{{likedCommentIds[reply.id] ? '#0052d9' : '#94a3b8'}}"
                    ></t-icon>
                    <text>{{reply.likeCount || 0}}</text>
                  </view>
                </view>
              </block>
            </view>
          </view>
          <view
            class="comment-row__like {{likedCommentIds[item.id] ? 'comment-row__like--active' : ''}}"
            bindtap="onLikeComment"
            data-id="{{item.id}}"
          >
            <t-icon
              name="{{likedCommentIds[item.id] ? 'thumb-up-filled' : 'thumb-up'}}"
              size="28rpx"
              color="{{likedCommentIds[item.id] ? '#0052d9' : '#94a3b8'}}"
            ></t-icon>
            <text>{{item.likeCount || 0}}</text>
          </view>
        </view>
      </block>

      <view wx:if="{{comments.length}}" class="comment-panel__list-footer">
        <view wx:if="{{commentLoadingMore}}" class="comment-panel__list-footer-loading">
          <t-loading size="32rpx" text="加载中..." />
        </view>
        <text wx:elif="{{!commentHasMore}}" class="comment-panel__list-footer-end">— 已加载全部 —</text>
      </view>
    </scroll-view>

    <view class="comment-panel__footer">
      <view wx:if="{{replyParentId}}" class="comment-reply-bar">
        <view class="comment-reply-bar__main">
          <view class="comment-reply-bar__head">
            <text class="comment-reply-bar__label">正在回复</text>
            <text class="comment-reply-bar__name">@{{replyTargetName}}</text>
            <view class="comment-reply-bar__cancel" bindtap="onCancelReply">
              <t-icon name="close" size="28rpx" color="#999"></t-icon>
            </view>
          </view>
          <text wx:if="{{replyTargetContent}}" class="comment-reply-bar__preview">{{replyTargetContent}}</text>
        </view>
      </view>
      <view class="comment-input-bar">
        <input
          class="comment-input-bar__field"
          value="{{commentText}}"
          placeholder="{{commentPlaceholder}}"
          maxlength="200"
          confirm-type="send"
          bindinput="onCommentChange"
          bindconfirm="onSubmitComment"
        />
        <text class="comment-input-bar__send {{commentText ? 'comment-input-bar__send--active' : ''}}" bindtap="onSubmitComment">发送</text>
      </view>
    </view>
  </view>
</t-popup>

<!-- 分享面板 -->
<t-popup
  visible="{{showShareActionSheet}}"
  placement="bottom"
  bind:visible-change="onSharePanelVisibleChange"
>
  <view class="share-panel">
    <view class="share-panel__handle" />
    <view class="share-panel__head">
      <text class="share-panel__title">更多操作</text>
      <text class="share-panel__sub">分享题目或进行其他操作</text>
    </view>

    <block wx:for="{{sharePanels}}" wx:key="title" wx:for-item="panel">
      <view class="share-panel__section">
        <text wx:if="{{panel.title}}" class="share-panel__section-title">{{panel.title}}</text>
        <view class="share-panel__grid">
          <view
            wx:for="{{panel.items}}"
            wx:for-item="item"
            wx:key="value"
            class="share-panel__item"
            data-value="{{item.value}}"
            bindtap="onShareOptionTap"
            hover-class="share-panel__item--pressed"
          >
            <view class="share-panel__icon share-panel__icon--{{item.tone}}">
              <t-icon name="{{item.icon}}" size="44rpx" />
            </view>
            <text class="share-panel__label">{{item.label}}</text>
          </view>
        </view>
      </view>
    </block>

    <view class="share-panel__cancel" bindtap="onShareActionSheetClose" hover-class="share-panel__cancel--pressed">
      取消
    </view>
  </view>
</t-popup>

<!-- 分享引导 -->
<t-popup
  visible="{{showCustomGuide}}"
  bind:visible-change="onCloseCustomGuide"
  placement="center"
  overlay-props="{{ { background: 'rgba(15, 23, 42, 0.55)' } }}"
>
  <view class="share-guide">
    <view class="share-guide__icon-wrap">
      <t-icon name="logo-wechat-stroke" size="56rpx" color="#07c160" />
    </view>
    <text class="share-guide__title">分享给微信好友</text>
    <view class="share-guide__steps">
      <view class="share-guide__step">
        <text class="share-guide__step-num">1</text>
        <text class="share-guide__step-text">点击右上角「···」菜单</text>
      </view>
      <view class="share-guide__step">
        <text class="share-guide__step-num">2</text>
        <text class="share-guide__step-text">选择「转发」发送给好友</text>
      </view>
    </view>
    <view class="share-guide__btn" bindtap="onCloseCustomGuide" hover-class="share-guide__btn--pressed">
      知道了
    </view>
  </view>
</t-popup>

<t-message id="t-message" />
