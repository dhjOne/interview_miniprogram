<!-- pages/question/detail/index.wxml -->
<view class="question-detail-container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-content">
      <t-loading size="60rpx" text="加载中..."></t-loading>
    </view>
  </view>

  <!-- 错误状态 -->
  <view wx:elif="{{error}}" class="error-state">
    <view class="error-content">
      <t-icon name="error-circle" size="120rpx" color="#ff4d4f"></t-icon>
      <text class="error-text">{{errorMessage || '加载失败'}}</text>
      <t-button theme="primary" bindtap="retryLoad" class="retry-btn">
        重新加载
      </t-button>
    </view>
  </view>

  <!-- 空数据状态 -->
  <view wx:elif="{{isEmpty}}" class="empty-state">
    <view class="empty-content">
      <t-icon name="file" size="120rpx" color="#ccc"></t-icon>
      <text class="empty-text">题目不存在</text>
      <text class="empty-desc">该题目可能已被删除或不存在</text>
      <t-button theme="outline" bindtap="goBack" class="empty-btn">
        返回上一页
      </t-button>
    </view>
  </view>

  <!-- 正常内容 -->
  <view wx:else class="detail-main">
    <scroll-view class="content-scroll" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="question-card">
        <view class="question-header">
          <view class="question-title-section">
            <text class="question-title">{{questionDetail.title}}</text>
            <view wx:if="{{questionDetail.categoryName}}" class="category-tag">
              <t-tag theme="primary" size="small">{{questionDetail.categoryName}}</t-tag>
            </view>
          </view>

          <!-- 作者信息 + 关注（始终展示） -->
          <view class="author-info-section">
            <view class="author-info">
              <view class="author-basic">
                <view
                  class="author-avatar author-avatar--tap"
                  hover-class="author-avatar--pressed"
                  hover-stay-time="80"
                  catchtap="onAuthorTap"
                >
                  <image
                    wx:if="{{questionDetail.authorAvatar || questionDetail.createAvatar}}"
                    class="author-avatar-img"
                    src="{{questionDetail.authorAvatar || questionDetail.createAvatar}}"
                    mode="aspectFill"
                  />
                  <t-icon wx:else name="user-circle" size="48rpx" color="#1890ff"></t-icon>
                </view>
                <view
                  class="author-details author-details--tap"
                  hover-class="author-details--pressed"
                  hover-stay-time="80"
                  catchtap="onAuthorTap"
                >
                  <text class="author-name">{{authorDisplayName}}</text>
                  <view class="author-meta">
                    <text wx:if="{{questionDetail.createdAt}}" class="meta-item">{{questionDetail.createdAt}}</text>
                    <text wx:if="{{questionDetail.createdAt && questionDetail.wordCount}}" class="meta-divider">·</text>
                    <text wx:if="{{questionDetail.wordCount}}" class="meta-item">{{questionDetail.wordCount}}字</text>
                    <text wx:if="{{questionDetail.viewCount}}" class="meta-divider">·</text>
                    <text wx:if="{{questionDetail.viewCount}}" class="meta-item">{{questionDetail.viewCount}} 阅读</text>
                  </view>
                </view>
              </view>
              <view
                class="follow-btn {{authorFollowing ? 'follow-btn--followed' : ''}}"
                hover-class="follow-btn--pressed"
                hover-stay-time="80"
                bindtap="onToggleFollow"
              >
                <t-icon
                  wx:if="{{!authorFollowing}}"
                  name="add"
                  size="28rpx"
                  class="follow-btn__icon"
                />
                <t-icon
                  wx:else
                  name="check"
                  size="28rpx"
                  class="follow-btn__icon follow-btn__icon--muted"
                />
                <text class="follow-btn__text">{{authorFollowing ? '已关注' : '关注'}}</text>
              </view>
            </view>
          </view>
        </view>

        <view class="content-area">
          <block wx:if="{{isMarkdown && towxmlData}}">
            <view class="markdown-content">
              <towxml nodes="{{towxmlData}}" />
            </view>
          </block>

          <block wx:else>
            <view class="content-blocks">
              <block wx:for="{{contentBlocks}}" wx:key="id" wx:for-index="index">
                <view wx:if="{{item.blockType === 'text'}}" class="content-block text-block {{item.customClass}}"
                  style="{{item.customStyle}}" data-block-id="{{item.id}}" data-block-type="text">
                  <block wx:if="{{item.textInfo.hasLineBreaks}}">
                    <block wx:for="{{item.textInfo.lines}}" wx:key="index">
                      <view class="text-line {{index > 0 ? 'indented-line' : ''}}">
                        <rich-text wx:if="{{item.textInfo.hasBoldText || item.contentFormat === 'markdown'}}"
                          nodes="{{item}}" class="rich-text-content">
                        </rich-text>
                        <text wx:else class="text-content" selectable>{{item}}</text>
                      </view>
                    </block>
                  </block>
                  <block wx:else>
                    <rich-text wx:if="{{item.textInfo.hasBoldText || item.contentFormat === 'markdown'}}"
                      nodes="{{item.textInfo.formattedContent}}" class="rich-text-content">
                    </rich-text>
                    <text wx:else class="text-content" selectable>{{item.textInfo.formattedContent}}</text>
                  </block>
                </view>

                <view wx:elif="{{item.blockType === 'code'}}" class="content-block code-block {{item.customClass}}"
                  style="{{item.customStyle}}" data-block-id="{{item.id}}" data-block-type="code" bindtap="onBlockTap">
                  <view class="code-header">
                    <text class="code-language">{{item.formattedContent.language}}</text>
                    <view class="code-actions" catchtap="copyCode" data-content="{{item.content}}">
                      <t-icon name="copy" size="24rpx"></t-icon>
                      <text>复制</text>
                    </view>
                  </view>
                  <view class="code-content">
                    <text class="code-text" selectable>{{item.content}}</text>
                  </view>
                </view>

                <view wx:elif="{{item.blockType === 'image'}}" class="content-block image-block {{item.customClass}}"
                  style="{{item.customStyle}}" data-block-id="{{item.id}}" data-block-type="image" bindtap="onBlockTap">
                  <image src="{{item.imageInfo.src}}" mode="widthFix" class="content-image"
                    data-src="{{item.imageInfo.src}}"></image>
                  <view wx:if="{{item.imageInfo.caption}}" class="image-caption">
                    {{item.imageInfo.caption}}
                  </view>
                </view>

                <view wx:elif="{{item.blockType === 'table'}}" class="content-block table-block {{item.customClass}}"
                  style="{{item.customStyle}}" data-block-id="{{item.id}}" data-block-type="table">
                  <view class="table-container">
                    <view class="table-row table-header">
                      <block wx:for="{{item.tableData.headers}}" wx:key="*this">
                        <view class="table-cell header-cell">{{item}}</view>
                      </block>
                    </view>
                    <block wx:for="{{item.tableData.rows}}" wx:key="index">
                      <view class="table-row">
                        <block wx:for="{{item}}" wx:key="*this">
                          <view class="table-cell">{{item}}</view>
                        </block>
                      </view>
                    </block>
                  </view>
                </view>

                <view wx:elif="{{item.blockType === 'formula'}}"
                  class="content-block formula-block {{item.customClass}} {{item.formulaInfo.isInline ? 'formula-inline' : 'formula-block'}}"
                  style="{{item.customStyle}}" data-block-id="{{item.id}}" data-block-type="formula">
                  <view class="formula-content">{{item.content}}</view>
                </view>

                <view wx:elif="{{item.blockType === 'file'}}" class="content-block file-block {{item.customClass}}"
                  style="{{item.customStyle}}" data-block-id="{{item.id}}" data-block-type="file" bindtap="onBlockTap">
                  <view class="file-info">
                    <t-icon name="file" size="40rpx"></t-icon>
                    <view class="file-details">
                      <text class="file-name">{{item.fileInfo.fileName}}</text>
                      <text class="file-size">{{item.fileInfo.fileSize}}</text>
                    </view>
                    <t-icon name="download" size="32rpx"></t-icon>
                  </view>
                </view>

                <view wx:elif="{{item.blockType === 'divider'}}"
                  class="content-block divider-block {{item.customClass}}" style="{{item.customStyle}}"
                  data-block-id="{{item.id}}" data-block-type="divider">
                </view>

                <view wx:elif="{{item.blockType === 'video'}}" class="content-block video-block {{item.customClass}}"
                  style="{{item.customStyle}}" data-block-id="{{item.id}}" data-block-type="video">
                  <video src="{{item.videoInfo.src}}" poster="{{item.videoInfo.poster}}"
                    controls="{{item.videoInfo.controls}}" autoplay="{{item.videoInfo.autoplay}}"
                    class="content-video"></video>
                </view>

                <view wx:else class="content-block unknown-block">
                  <text>未知块类型: {{item.blockType}}</text>
                </view>
              </block>
            </view>
          </block>
        </view>
      </view>

      <view class="bottom-placeholder"></view>
    </scroll-view>

    <!-- 底部导航栏 -->
    <view class="detail-bottom-bar">
      <view class="bottom-bar__nav">
        <view class="bottom-nav-item" bindtap="onOpenCatalog">
          <t-icon name="view-list" size="40rpx" color="#333"></t-icon>
          <text>目录</text>
        </view>
        <view class="bottom-nav-item bottom-nav-item--comment" bindtap="onOpenComments">
          <t-icon name="chat" size="40rpx" color="#333"></t-icon>
          <text>评论</text>
          <text wx:if="{{questionDetail.commentCount}}" class="bottom-nav-badge">{{questionDetail.commentCount}}</text>
        </view>
      </view>

      <view class="bottom-bar__actions">
        <view class="bottom-action-item {{questionDetail.liked ? 'like-active' : ''}}" bindtap="onLike">
          <t-icon name="{{questionDetail.liked ? 'thumb-up-filled' : 'thumb-up'}}" size="40rpx"
            color="{{questionDetail.liked ? '#ff6b6b' : '#666'}}"></t-icon>
          <text class="bottom-action-count">{{questionDetail.likeCount || 0}}</text>
        </view>
        <view class="bottom-action-item {{questionDetail.collected ? 'collect-active' : ''}}" bindtap="onCollect">
          <t-icon name="{{questionDetail.collected ? 'heart-filled' : 'heart'}}" size="40rpx"
            color="{{questionDetail.collected ? '#ff6b6b' : '#666'}}"></t-icon>
          <text class="bottom-action-count">{{questionDetail.collectCount || 0}}</text>
        </view>
        <view class="bottom-action-item bottom-action-item--share" bindtap="onShare">
          <t-icon name="share" size="40rpx" color="#666"></t-icon>
          <text>分享</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 题目目录侧栏 -->
<t-popup
  visible="{{showCatalog}}"
  placement="left"
  bind:visible-change="onCatalogVisibleChange"
>
  <view class="catalog-drawer">
    <view class="catalog-drawer__head">
      <text class="catalog-drawer__title">题目目录</text>
      <text class="catalog-drawer__sub">{{catalogTitle}}</text>
    </view>

    <view wx:if="{{catalogLoading}}" class="catalog-drawer__loading">
      <t-loading size="48rpx" text="加载目录…"></t-loading>
    </view>

    <scroll-view wx:else class="catalog-drawer__list" scroll-y show-scrollbar="{{false}}">
      <view wx:if="{{!catalogList.length}}" class="catalog-drawer__empty">
        <t-icon name="folder-open" size="80rpx" color="#ccc"></t-icon>
        <text>暂无同分类题目</text>
        <text class="catalog-drawer__empty-hint">从题库列表进入可浏览完整目录</text>
      </view>

      <view
        wx:for="{{catalogList}}"
        wx:key="id"
        class="catalog-item {{item.id == questionId ? 'catalog-item--active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onCatalogItemTap"
      >
        <text class="catalog-item__index">{{item.index}}</text>
        <view class="catalog-item__main">
          <text class="catalog-item__title">{{item.title}}</text>
          <text wx:if="{{item.displayDate}}" class="catalog-item__meta">{{item.displayDate}}</text>
        </view>
        <t-icon wx:if="{{item.id == questionId}}" name="check-circle-filled" size="36rpx" color="#1890ff"></t-icon>
      </view>
    </scroll-view>
  </view>
</t-popup>

<!-- 评论底部面板 -->
<t-popup
  visible="{{showCommentPanel}}"
  placement="bottom"
  bind:visible-change="onCommentPanelVisibleChange"
>
  <view class="comment-panel">
    <view class="comment-panel__head">
      <text class="comment-panel__title">评论 {{questionDetail.commentCount || 0}}</text>
      <view class="comment-panel__close" bindtap="onCloseComments">
        <t-icon name="close" size="40rpx" color="#999"></t-icon>
      </view>
    </view>

    <scroll-view class="comment-panel__list" scroll-y show-scrollbar="{{false}}">
      <view wx:if="{{!comments.length}}" class="comment-panel__empty">
        <t-icon name="chat" size="80rpx" color="#ddd"></t-icon>
        <text>还没有评论，来抢沙发吧</text>
      </view>

      <block wx:for="{{comments}}" wx:key="id">
        <view class="comment-item">
          <view class="comment-header">
            <image class="comment-avatar" src="{{item.avatar || '/static/avatar1.png'}}"></image>
            <view class="comment-user">
              <text class="user-name">{{item.userName || item.nickname || '匿名用户'}}</text>
              <text class="comment-time">{{item.createTime || item.timeText}}</text>
            </view>
          </view>
          <view class="comment-content">{{item.content}}</view>
          <view class="comment-actions">
            <view class="action-item" bindtap="onLikeComment" data-id="{{item.id}}">
              <t-icon name="thumb-up" size="24rpx"></t-icon>
              <text>{{item.likeCount || 0}}</text>
            </view>
            <view class="action-item" bindtap="onReplyComment" data-id="{{item.id}}">
              <t-icon name="chat" size="24rpx"></t-icon>
              <text>回复</text>
            </view>
          </view>
        </view>
      </block>
    </scroll-view>

    <view class="comment-panel__input">
      <t-textarea
        value="{{commentText}}"
        placeholder="写下你的评论…"
        maxlength="200"
        autosize
        bind:change="onCommentChange"
      />
      <t-button theme="primary" size="small" bindtap="onSubmitComment" class="comment-panel__submit">
        发布
      </t-button>
    </view>
  </view>
</t-popup>

<!-- 分享 ActionSheet -->
<t-action-sheet id="t-action-sheet" visible="{{showShareActionSheet}}" bind:close="onShareActionSheetClose"
  bind:cancel="onShareActionSheetClose" bind:selected="onShareOptionSelect" theme="grid" align="center"
  items="{{shareOptions}}" cancel-text="取消分享" class="share-action-sheet" />

<!-- 分享引导 -->
<t-popup visible="{{showCustomGuide}}" bind:visible-change="onCloseCustomGuide" placement="center"
  overlay-props="{{ { background: 'rgba(0, 0, 0, 0.6)' } }}">
  <view class="custom-guide-popup">
    <view class="guide-header">
      <t-icon name="share" size="48rpx" color="#07c160"></t-icon>
      <text class="guide-title">分享指引</text>
    </view>
    <view class="guide-content">
      <text class="guide-text">请点击右上角"···"按钮</text>
      <text class="guide-text">然后选择"转发"将题目分享给好友</text>
    </view>
    <view class="guide-actions">
      <t-button theme="primary" bindtap="onCloseCustomGuide" size="large">知道了</t-button>
    </view>
  </view>
</t-popup>

<t-message id="t-message" />
