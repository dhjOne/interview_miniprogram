<view class="user-profile">
  <t-navbar
    left-arrow
    title="{{profile.nickname || '个人主页'}}"
    fixed
    safe-area-inset-top
    t-class="user-profile__navbar"
  />

  <view class="user-profile__inner">
    <view wx:if="{{pageLoading}}" class="user-profile__loading">
      <t-loading size="48rpx" text="加载中…" />
    </view>

    <block wx:else>
      <view class="profile-cover">
        <view class="profile-cover__wash" />
        <view class="profile-cover__glow" />
      </view>

      <view class="profile-panel">
        <view class="profile-identity">
          <view class="profile-identity__avatar-ring">
            <t-avatar
              image="{{profile.avatar || defaultAvatar}}"
              size="148rpx"
            />
          </view>
          <view class="profile-identity__info">
            <text class="profile-identity__name">{{profile.nickname}}</text>
            <text wx:if="{{profile.bio}}" class="profile-identity__bio">{{profile.bio}}</text>
            <text wx:else class="profile-identity__bio profile-identity__bio--muted">这个人很懒，还没有简介</text>
            <view wx:if="{{profile.auditStatus === 0 || profile.auditStatus === 2}}" class="profile-identity__status">
              <text wx:if="{{profile.auditStatus === 0}}">资料审核中</text>
              <text wx:if="{{profile.auditStatus === 2}}">资料审核未通过</text>
            </view>
          </view>
        </view>

        <view class="profile-stats">
          <view class="profile-stats__item">
            <text class="profile-stats__num">{{profile.followingCount}}</text>
            <text class="profile-stats__label">关注</text>
          </view>
          <view class="profile-stats__item">
            <text class="profile-stats__num">{{profile.followerCount}}</text>
            <text class="profile-stats__label">粉丝</text>
          </view>
          <view class="profile-stats__item">
            <text class="profile-stats__num">{{profile.publishCount}}</text>
            <text class="profile-stats__label">发布</text>
          </view>
          <view class="profile-stats__item">
            <text class="profile-stats__num">{{profile.likeCount}}</text>
            <text class="profile-stats__label">获赞</text>
          </view>
        </view>

        <view class="profile-actions" wx:if="{{!isSelf}}">
          <t-button
            class="profile-actions__follow"
            shape="round"
            size="medium"
            theme="{{profile.isBlocked || profile.isBlockedByTarget ? 'light' : (profile.isFollowing ? 'light' : 'primary')}}"
            variant="{{profile.isFollowing ? 'outline' : 'base'}}"
            disabled="{{profile.isBlocked || profile.isBlockedByTarget}}"
            bind:tap="onToggleFollow"
          >
            {{profile.isBlocked || profile.isBlockedByTarget ? '已限制互动' : (profile.isFollowing ? '已关注' : '关注')}}
          </t-button>
          <t-button
            class="profile-actions__more"
            shape="round"
            size="medium"
            theme="light"
            variant="outline"
            bind:tap="onMoreTap"
          >
            更多
          </t-button>
        </view>
        <view class="profile-actions" wx:else>
          <t-button class="profile-actions__self" shape="round" size="medium" theme="light" variant="outline" disabled>
            当前账号主页
          </t-button>
        </view>
      </view>

      <view class="profile-feed">
        <view class="profile-feed__head">
          <text class="profile-feed__title">作品</text>
          <text class="profile-feed__count">{{totalCount || articleList.length}} 篇</text>
        </view>

        <scroll-view class="profile-feed__tabs" scroll-x enhanced show-scrollbar="{{false}}">
          <view class="profile-feed__tabs-row">
            <view
              wx:for="{{categories}}"
              wx:key="id"
              class="profile-feed__tab {{item.id === activeCategory ? 'profile-feed__tab--active' : ''}}"
              data-category="{{item.id}}"
              bindtap="onCategoryChange"
            >
              <text>{{item.name}}</text>
              <text wx:if="{{item.count > 0}}" class="profile-feed__tab-count">{{item.count}}</text>
            </view>
          </view>
        </scroll-view>

        <scroll-view
          class="profile-feed__scroll"
          scroll-y
          enhanced
          show-scrollbar="{{false}}"
          bindscrolltolower="onReachBottom"
          lower-threshold="100"
        >
          <view class="profile-feed__list">
            <view
              wx:for="{{articleList}}"
              wx:key="id"
              class="feed-card"
              hover-class="feed-card--active"
              data-id="{{item.id}}"
              data-title="{{item.title}}"
              bindtap="onArticleTap"
            >
              <view class="feed-card__body">
                <text class="feed-card__title">{{item.title}}</text>
                <view class="feed-card__footer">
                  <view wx:if="{{item.categoryLabel}}" class="feed-card__cat">{{item.categoryLabel}}</view>
                  <view class="feed-card__meta">
                    <text>{{item.displayDate}}</text>
                    <text class="feed-card__dot">·</text>
                    <text>{{item.viewCount || 0}} 阅读</text>
                    <text class="feed-card__dot">·</text>
                    <text>{{item.likeCount || 0}} 赞</text>
                  </view>
                </view>
              </view>
              <t-icon name="chevron-right" size="32rpx" color="#cbd5e1" />
            </view>
          </view>

          <view class="profile-feed__foot" wx:if="{{articleList.length > 0}}">
            <view wx:if="{{listLoading}}" class="profile-feed__loading">
              <t-loading size="36rpx" text="加载中…" />
            </view>
            <text wx:elif="{{!hasMore}}" class="profile-feed__end">没有更多了</text>
          </view>

          <view wx:if="{{!listLoading && listDone && articleList.length === 0}}" class="profile-feed__empty">
            <view class="profile-feed__empty-icon">
              <t-icon name="file" size="72rpx" color="#cbd5e1" />
            </view>
            <text class="profile-feed__empty-title">{{activeCategory !== 'all' ? '此分类暂无作品' : '还没有发布作品'}}</text>
            <text class="profile-feed__empty-desc">TA 发布的内容会出现在这里</text>
          </view>

          <view wx:if="{{!listLoading && listError}}" class="profile-feed__empty">
            <view class="profile-feed__empty-icon profile-feed__empty-icon--warn">
              <t-icon name="error-circle" size="72rpx" color="#f59e0b" />
            </view>
            <text class="profile-feed__empty-title">作品加载失败</text>
            <t-button theme="light" size="medium" shape="round" bind:tap="reloadArticles">重试</t-button>
          </view>

          <view class="profile-feed__safe" />
        </scroll-view>
      </view>
    </block>
  </view>
</view>
