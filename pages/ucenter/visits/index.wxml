<view class="uc-social">
  <t-navbar left-arrow title="{{pageTitle}}" fixed safe-area-inset-top />
  <view class="uc-social__inner">
    <view class="uc-social__hero">
      <view class="uc-social__hero-title">{{heroTitle}}</view>
      <view class="uc-social__hero-sub">{{heroSub}}</view>
    </view>

    <scroll-view
      class="uc-social__scroll"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      bindscrolltolower="onReachBottom"
      lower-threshold="100"
    >
      <view wx:if="{{loading && list.length === 0}}" class="uc-social__loading">
        <t-loading size="48rpx" text="加载中…" />
      </view>

      <view class="uc-social__list">
        <view wx:for="{{list}}" wx:key="userId" class="uc-social__row">
          <t-avatar image="{{item.avatar || defaultAvatar}}" size="88rpx" />
          <view class="uc-social__main">
            <text class="uc-social__name">{{item.nickname}}</text>
            <text wx:if="{{item.bio}}" class="uc-social__bio">{{item.bio}}</text>
            <text wx:if="{{item.timeText}}" class="uc-social__time">访问于 {{item.timeText}}</text>
          </view>
          <view class="uc-social__action">
            <t-icon name="browse" size="40rpx" color="var(--td-text-color-placeholder, rgba(0,0,0,.35))" />
          </view>
        </view>
      </view>

      <view class="uc-social__foot" wx:if="{{list.length > 0}}">
        <view wx:if="{{loading}}">
          <t-loading size="36rpx" text="加载中…" />
        </view>
        <t-divider wx:elif="{{!hasMore}}" align="center" content="没有更多了" />
      </view>

      <view wx:if="{{!loading && loadDone && list.length === 0 && !loadError}}" class="uc-social__empty">
        <t-icon name="browse" size="120rpx" color="#ddd" />
        <text class="uc-social__empty-t">暂无访问记录</text>
        <text class="uc-social__empty-d">完善个人资料，更容易被其他用户发现</text>
      </view>

      <view wx:if="{{!loading && loadError}}" class="uc-social__empty">
        <t-icon name="error-circle" size="100rpx" color="#f5a524" />
        <text class="uc-social__empty-t">加载失败</text>
        <t-button theme="light" size="medium" shape="round" bind:tap="reload">重试</t-button>
      </view>
    </scroll-view>
  </view>
</view>
